{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "reset:soft": "node --import tsx src/scripts/resetDb.ts soft",
    "reset:hard": "node --import tsx src/scripts/resetDb.ts hard",
    "test:jira-integration": "tsx src/scripts/testJiraIntegration.ts",
    "test:email-integration": "tsx src/scripts/testEmailIntegration.ts"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^6.2.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.8",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
